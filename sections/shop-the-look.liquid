{%- liquid
  assign modal_btn_style = section.settings.modal_button_style | default: 'primary'
  assign primary_btn_style = section.settings.primary_button_style | default: 'primary'
  assign secondary_btn_style = section.settings.secondary_button_style | default: 'secondary'
-%}

{%- capture arrow_svg -%}
<svg width="27" height="11" viewBox="0 0 27 11" fill="none" aria-hidden="true" focusable="false">
  <line x1="0" y1="5.5" x2="22" y2="5.5" stroke="currentColor" stroke-width="1.2"/>
  <polyline points="18,1 23,5.5 18,10" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round"/>
</svg>
{%- endcapture -%}

<style>
  #stl-{{ section.id }} {
    --stl-heading: clamp(28px, 2.5vw, 36px);
    --stl-body: 14px;
    --stl-ui: 16px;
    --stl-gap: {{ section.settings.grid_gap }}px;
    --stl-card-radius: {{ section.settings.card_corner_radius }}px;
  }

  #stl-{{ section.id }} .stl-inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  #stl-{{ section.id }} .stl-heading {
    font-family: var(--font-lustria, Georgia, 'Times New Roman', serif);
    font-weight: 400;
    font-size: var(--stl-heading);
    line-height: 1.2;
    color: #000;
    margin: 0 0 30px;
  }

  #stl-{{ section.id }} .stl-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--stl-gap);
    align-items: flex-start;
  }

  #stl-{{ section.id }} .stl-card {
    position: relative;
    flex: 1 1 calc((100% - var(--stl-gap) * 2) / 3);
    min-width: 260px;
    max-width: 100%;
    border-radius: var(--stl-card-radius);
    overflow: hidden;
    line-height: 0;
  }

  @media screen and (max-width: 1100px) {
    #stl-{{ section.id }} .stl-card {
      flex: 1 1 calc((100% - var(--stl-gap)) / 2);
    }
  }

  @media screen and (max-width: 600px) {
    #stl-{{ section.id }} {
      --stl-gap: 4px;
    }

    #stl-{{ section.id }} .stl-card {
      flex: 1 1 calc((100% - var(--stl-gap)) / 2);
      min-width: 0;
    }
  }

  #stl-{{ section.id }} .stl-card__media {
    aspect-ratio: 433 / 444;
    width: 100%;
    background: #e8e8e8;
  }

  #stl-{{ section.id }} .stl-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /*
    Hotspot: visual ring stays 22px (design); button is min 44×44px for touch targets (WCAG).
    Center of the enlarged control stays on the same percentage point (translate -50% -50%).
  */
  #stl-{{ section.id }} .stl-hotspot {
    position: absolute;
    min-width: 44px;
    min-height: 44px;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transform: translate(-50%, -50%);
    line-height: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #stl-{{ section.id }} .stl-hotspot:focus-visible {
    outline: 2px solid #000;
    outline-offset: 2px;
  }

  #stl-{{ section.id }} .stl-hotspot__ring {
    position: relative;
    display: block;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgb(0 0 0 / 0.45);
    box-shadow: 0 0 0 1px rgb(255 255 255 / 0.6);
    flex-shrink: 0;
  }

  #stl-{{ section.id }} .stl-hotspot__ring::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 9px;
    height: 9px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: #fff;
  }

  /* ── CTA buttons (same behavior as header-banner) ── */
  #stl-{{ section.id }} .hb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: clamp(6px, 0.694vw, 26.7px);
    font-family: var(--font-jost, system-ui, sans-serif);
    font-weight: 400;
    font-size: var(--stl-ui);
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.35s ease;
    line-height: 1;
    width: 100%;
    box-sizing: border-box;
  }

  #stl-{{ section.id }} .hb-btn__label,
  #stl-{{ section.id }} .hb-btn__arrow {
    position: relative;
    z-index: 1;
    pointer-events: none;
    display: flex;
    align-items: center;
    transition: color 0.35s ease;
  }

  #stl-{{ section.id }} .hb-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease;
    z-index: 0;
  }

  #stl-{{ section.id }} .hb-btn:hover::before { transform: scaleX(1); }

  #stl-{{ section.id }} .hb-btn--primary {
    background: #000;
    color: #f5f5f5;
    padding: 14px 20px;
    min-height: 48px;
  }
  #stl-{{ section.id }} .hb-btn--primary::before { background: #fff544; }
  #stl-{{ section.id }} .hb-btn--primary:hover { color: #000; }

  #stl-{{ section.id }} .hb-btn--secondary {
    background: #fff544;
    color: #000;
    padding: 14px 20px;
    min-height: 48px;
  }
  #stl-{{ section.id }} .hb-btn--secondary::before { background: #000; }
  #stl-{{ section.id }} .hb-btn--secondary:hover { color: #fff; }

  /* ── Modal (Figma 43:351) ── */
  #stl-{{ section.id }} .stl-dialog {
    padding: 0;
    border: none;
    max-width: min(311px, 100vw - 32px);
    width: 100%;
    background: #fff;
    box-shadow: 0 2px 4px rgb(0 0 0 / 0.2);
    font-family: var(--font-jost, system-ui, sans-serif);
    color: #000;
  }

  #stl-{{ section.id }} .stl-dialog::backdrop {
    background: rgb(0 0 0 / 0.45);
  }

  #stl-{{ section.id }} .stl-dialog__panel {
    position: relative;
    padding: 36px 20px 20px;
  }

  #stl-{{ section.id }} .stl-dialog__close {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 28px;
    height: 28px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
  }

  #stl-{{ section.id }} .stl-dialog__close svg {
    width: 11px;
    height: 11px;
    display: block;
  }

  /* Image left + title / price / copy right */
  #stl-{{ section.id }} .stl-dialog__hero {
    display: grid;
    grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
    gap: 12px 14px;
    align-items: start;
    margin-bottom: 14px;
  }

  @media screen and (max-width: 380px) {
    #stl-{{ section.id }} .stl-dialog__hero {
      grid-template-columns: 1fr;
    }
  }

  #stl-{{ section.id }} .stl-dialog__image-wrap {
    position: relative;
    aspect-ratio: 118 / 154;
    background: #f2f2f2;
    overflow: hidden;
  }

  #stl-{{ section.id }} .stl-dialog__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #stl-{{ section.id }} .stl-dialog__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f2f2f2;
    color: #999;
  }

  #stl-{{ section.id }} .stl-dialog__image-placeholder svg {
    width: 48px;
    height: auto;
    opacity: 0.45;
  }

  #stl-{{ section.id }} .stl-dialog__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding-top: 4px;
  }

  #stl-{{ section.id }} .stl-dialog__title {
    font-family: var(--font-jost, system-ui, sans-serif);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
    margin: 0;
  }

  #stl-{{ section.id }} .stl-dialog__price {
    font-family: var(--font-lustria, Georgia, 'Times New Roman', serif);
    font-weight: 400;
    font-style: normal;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
    margin: 0;
    margin-top: 22px;
    margin-bottom: 12px;
  }

  #stl-{{ section.id }} .stl-dialog__desc {
    font-family: var(--font-jost, system-ui, sans-serif);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #000;
    margin: 0;
    max-width: 14em;
  }

  #stl-{{ section.id }} .stl-dialog__options {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #stl-{{ section.id }} .stl-field-label {
    font-size: 14px;
    line-height: 1.3;
    color: #333;
    margin: 0 0 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  #stl-{{ section.id }} .stl-field-label__info {
    display: inline-flex;
    color: #333;
    flex-shrink: 0;
  }

  /*
    Color options — Figma 103:150: outer 0.5px border; unselected = light gray cell + 4px strip (JSON hex);
    selected = black fill + white label (strip keeps variant color).
  */
  #stl-{{ section.id }} .stl-color-swatches {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    width: 100%;
    max-width: 100%;
    margin: 0 0 14px;
    border: 0.5px solid #000;
    box-sizing: border-box;
    background: #f0f0f0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #stl-{{ section.id }} .stl-swatch--color {
    flex: 1 1 0;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    min-width: 0;
    min-height: 39px;
    margin: 0;
    padding: 0;
    border: none;
    cursor: pointer;
    font-family: var(--font-jost, system-ui, sans-serif);
    background: #f0f0f0;
    color: #000;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  #stl-{{ section.id }} .stl-swatch--color + .stl-swatch--color {
    border-left: 0.5px solid #000;
  }

  #stl-{{ section.id }} .stl-swatch__strip {
    width: 4px;
    flex-shrink: 0;
    align-self: stretch;
    min-height: 100%;
    background: var(--stl-swatch, #bdbdbd);
    box-sizing: border-box;
  }

  #stl-{{ section.id }} .stl-swatch__label {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.36px;
    text-transform: capitalize;
    color: inherit;
  }

  #stl-{{ section.id }} .stl-swatch--color[data-selected='true'] {
    background: #000;
    color: #fff;
    z-index: 1;
  }

  #stl-{{ section.id }} .stl-swatch--color[data-selected='true'] .stl-swatch__label {
    color: #fff;
  }

  #stl-{{ section.id }} .stl-swatch--color:focus-visible {
    outline: 2px solid #000;
    outline-offset: 2px;
  }

  #stl-{{ section.id }} .stl-swatch--color[data-selected='true']:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  /* Size selector — Figma 116:989 / 116:552 (271×64): label + 36px field, 0.5px border, rule @79.7%, chevron right */
  #stl-{{ section.id }} .stl-size-field {
    width: 100%;
    max-width: 271px;
    min-height: 64px;
    margin: 0 0 14px;
    box-sizing: border-box;
  }

  #stl-{{ section.id }} .stl-size-field__head {
    width: 100%;
    margin: 0 0 6px;
    min-height: 18px;
  }

  #stl-{{ section.id }} .stl-size-field__head .stl-field-label {
    margin: 0;
    font-family: var(--font-jost, system-ui, sans-serif);
  }

  #stl-{{ section.id }} .stl-select-wrap {
    position: relative;
    width: 100%;
  }

  #stl-{{ section.id }} .stl-select-wrap--size .stl-select {
    width: 100%;
    max-width: 271px;
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--font-jost, system-ui, sans-serif);
    font-size: 16px;
    font-weight: 400;
    /* inset ~4.8% left, ~26.94% right (Figma “Choose your size” box) */
    padding: 9px 73px 10px 13px;
    height: 39px;
    min-height: 36px;
    border: 0.5px solid #000;
    border-radius: 0;
    background: #fff;
    color: #000;
    cursor: pointer;
    letter-spacing: -0.32px;
    line-height: 1;
    box-sizing: border-box;
  }

  #stl-{{ section.id }} .stl-select-wrap--size .stl-select:focus-visible {
    outline: 2px solid #000;
    outline-offset: 2px;
  }

  /* Vertical rule at left edge of this strip (~79.7%); chevron inset ~7.75% from select right */
  #stl-{{ section.id }} .stl-select__decor {
    position: absolute;
    left: 79.7%;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    height: 36px;
    padding-right: 7.75%;
    box-sizing: border-box;
    pointer-events: none;
  }

  #stl-{{ section.id }} .stl-select__line {
    width: 0.5px;
    height: 100%;
    background: #000;
    flex-shrink: 0;
    align-self: center;
  }

  #stl-{{ section.id }} .stl-select__chevron {
    display: block;
    flex-shrink: 0;
    color: #000;
  }

  #stl-{{ section.id }} .stl-select-wrap--size .stl-select__chevron {
    margin-left: auto;
  }

  /* Generic option selects (non-size) */
  #stl-{{ section.id }} .stl-select-wrap:not(.stl-select-wrap--size) .stl-select {
    width: 100%;
    appearance: none;
    font-family: var(--font-jost, system-ui, sans-serif);
    font-size: 16px;
    font-weight: 400;
    padding: 12px 36px 12px 12px;
    min-height: 40px;
    border: 0.5px solid #000;
    background: #fff;
    color: #000;
    cursor: pointer;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  #stl-{{ section.id }} .stl-select-wrap:not(.stl-select-wrap--size)::after {
    content: '';
    position: absolute;
    right: 12px;
    top: 50%;
    width: 6px;
    height: 6px;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  #stl-{{ section.id }} .stl-dialog__footer {
    margin-top: 8px;
  }

  /* Full-bleed black CTA like Figma */
  #stl-{{ section.id }} .stl-dialog__footer .hb-btn {
    width: 100%;
    min-height: 44px;
    padding: 12px 16px;
    justify-content: center;
    gap: 8px;
  }

  #stl-{{ section.id }} .stl-dialog__footer .hb-btn__label {
    letter-spacing: 0.02em;
  }

  #stl-{{ section.id }} .stl-empty-state {
    padding: 24px;
    text-align: center;
    font-family: var(--font-paragraph--family, system-ui, sans-serif);
    font-size: 14px;
    color: #333;
  }

  #stl-{{ section.id }} shop-the-look-root {
    display: block;
    width: 100%;
  }
</style>

<section id="stl-{{ section.id }}" class="shop-the-look-section">
  <shop-the-look-root
    data-section-id="{{ section.id }}"
    data-currency="{{ cart.currency.iso_code }}"
    data-color-map-url="{{ 'color-variant-swatches.json' | asset_url }}"
    data-add-to-cart-label="{{ section.settings.add_to_cart_label | default: 'Add to cart' | escape }}"
    data-sold-out-label="{{ 'products.product.sold_out' | t | default: 'Sold out' | escape }}"
  >
  <div class="stl-inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="stl-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="stl-grid">
      {%- for block in section.blocks -%}
        {%- if block.type != 'look' -%}{%- continue -%}{%- endif -%}
        {%- liquid
          assign card_product = block.settings.product
          assign hx = block.settings.hotspot_x | default: 50
          assign hy = block.settings.hotspot_y | default: 50
        -%}
        <div class="stl-card" {{ block.shopify_attributes }}>
          <div class="stl-card__media">
            {%- if block.settings.image != blank -%}
              {{- block.settings.image
                | image_url: width: 900
                | image_tag:
                    loading: 'lazy',
                    widths: '400,600,900',
                    sizes: '(min-width: 1100px) 33vw, (min-width: 600px) 50vw, 100vw',
                    alt: block.settings.image.alt | default: card_product.title | default: 'Shop the look' -}}
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>

          <button
            type="button"
            class="stl-hotspot"
            style="left: {{ hx }}%; top: {{ hy }}%;"
            aria-haspopup="dialog"
            aria-controls="stl-dialog-{{ section.id }}-{{ block.id }}"
            data-stl-open="{{ block.id }}"
          >
            <span class="stl-hotspot__ring" aria-hidden="true"></span>
            <span class="visually-hidden">
              {{ block.settings.hotspot_accessibility_label | default: 'View product' | escape }}
            </span>
          </button>
        </div>

        <dialog
          id="stl-dialog-{{ section.id }}-{{ block.id }}"
          class="stl-dialog"
          data-stl-dialog
          aria-labelledby="stl-title-{{ section.id }}-{{ block.id }}"
        >
          <div class="stl-dialog__panel">
            <button
              type="button"
              class="stl-dialog__close"
              aria-label="{{ 'accessibility.close_dialog' | t }}"
              data-stl-close
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                <path d="M1.06067 9.54596L9.54595 1.06068" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
                <path d="M1.06067 1.06068L9.54595 9.54596" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
              </svg>
            </button>

            {%- if card_product != blank -%}
              {%- assign modal_variant = card_product.selected_or_first_available_variant -%}
              {%- assign product_form_id = 'stl-form-' | append: section.id | append: '-' | append: block.id -%}
              <div class="stl-dialog__hero">
                <div class="stl-dialog__image-wrap">
                  {%- if card_product.featured_media -%}
                    {{- card_product.featured_media
                      | image_url: width: 600
                      | image_tag:
                          loading: 'lazy',
                          widths: '200,300,450,600',
                          sizes: '180px',
                          alt: card_product.featured_media.alt | default: card_product.title -}}
                  {%- else -%}
                    <div class="stl-dialog__image-placeholder" aria-hidden="true">
                      {{- 'product-apparel-1' | placeholder_svg_tag -}}
                    </div>
                  {%- endif -%}
                </div>

                <div class="stl-dialog__meta">
                  <h3 id="stl-title-{{ section.id }}-{{ block.id }}" class="stl-dialog__title">
                    {{ card_product.title | escape }}
                  </h3>
                  <p class="stl-dialog__price" data-stl-price data-currency="{{ cart.currency.iso_code }}">
                    {{ modal_variant.price | money }}
                  </p>
                  {%- if card_product.description != blank -%}
                    <p class="stl-dialog__desc">
                      {{ card_product.description | strip_html | truncatewords: 40 | escape }}
                    </p>
                  {%- endif -%}
                </div>
              </div>

              {%- form 'product', card_product, id: product_form_id, class: 'stl-product-form', data-stl-product-form: '', novalidate: 'novalidate' -%}
                <input type="hidden" name="quantity" value="1">
                <input
                  type="hidden"
                  name="id"
                  value="{{ modal_variant.id }}"
                  data-stl-variant-input
                  {% if modal_variant.available == false %}
                    disabled
                  {% endif %}
                >

                <div class="stl-dialog__options" data-stl-options-root>
                  {%- if card_product.has_only_default_variant == false -%}
                    {%- for option in card_product.options_with_values -%}
                      {%- assign opt_idx = forloop.index0 -%}
                      {%- assign opt_name_down = option.name | downcase | strip -%}
                      {%- liquid
                        assign stl_is_color = false
                        assign stl_is_size = false
                        if opt_name_down == 'color' or opt_name_down == 'colors' or opt_name_down == 'colour' or opt_name_down == 'colours'
                          assign stl_is_color = true
                        elsif opt_name_down contains 'couleur' or opt_name_down contains 'farbe' or opt_name_down contains 'colore' or opt_name_down contains 'kleur' or opt_name_down contains 'färg' or opt_name_down contains 'farg' or opt_name_down contains 'väri'
                          assign stl_is_color = true
                        elsif opt_name_down contains ' color' or opt_name_down contains 'color ' or opt_name_down contains ' colour' or opt_name_down contains 'colour '
                          assign stl_is_color = true
                        endif
                        if opt_name_down == 'size' or opt_name_down == 'sizes'
                          assign stl_is_size = true
                        elsif opt_name_down contains 'taille' or opt_name_down contains 'größe' or opt_name_down contains 'groesse' or opt_name_down contains 'grosse' or opt_name_down contains 'talla' or opt_name_down contains 'misura' or opt_name_down contains 'maat' or opt_name_down contains 'rozmiar' or opt_name_down contains 'tamanho' or opt_name_down contains 'storlek' or opt_name_down contains 'størrelse' or opt_name_down contains 'storrelse' or opt_name_down contains 'koko'
                          assign stl_is_size = true
                        elsif opt_name_down contains ' size' or opt_name_down contains 'size ' or opt_name_down contains ' sizes'
                          assign stl_is_size = true
                        endif
                      -%}
                      {%- if stl_is_color -%}
                        <span class="stl-field-label">{{ option.name | escape }}</span>
                        <div
                          class="stl-swatches stl-color-swatches"
                          data-stl-option-index="{{ opt_idx }}"
                          role="group"
                          aria-label="{{ option.name | escape }}"
                        >
                          {%- for value in option.values -%}
                            <button
                              type="button"
                              class="stl-swatch stl-swatch--color"
                              data-value="{{ value | strip | escape }}"
                              data-selected="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                              aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                              title="{{ value | strip | escape }}"
                            >
                              <span class="stl-swatch__strip" aria-hidden="true"></span>
                              <span class="stl-swatch__label">{{ value | escape }}</span>
                            </button>
                          {%- endfor -%}
                        </div>
                      {%- elsif stl_is_size -%}
                        <div class="stl-size-field">
                          <div class="stl-size-field__head">
                            <label
                              class="stl-field-label stl-size-field__label"
                              for="stl-select-{{ section.id }}-{{ block.id }}-{{ opt_idx }}"
                            >
                              {{ option.name | escape }}
                            </label>
                          </div>
                          <div class="stl-select-wrap stl-select-wrap--size">
                            <select
                              id="stl-select-{{ section.id }}-{{ block.id }}-{{ opt_idx }}"
                              class="stl-select"
                              data-stl-option-index="{{ opt_idx }}"
                              data-stl-size-select
                            >
                              {%- for value in option.values -%}
                                <option
                                  value="{{ value | escape }}"
                                  {% if option.selected_value == value %}
                                    selected
                                  {% endif %}
                                >
                                  {{ value | escape }}
                                </option>
                              {%- endfor -%}
                            </select>
                            <span class="stl-select__decor" aria-hidden="true">
                              <span class="stl-select__line"></span>
                              <svg class="stl-select__chevron" width="11" height="7" viewBox="0 0 11 7" fill="none">
                                <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </span>
                          </div>
                        </div>
                      {%- else -%}
                        <label class="stl-field-label" for="stl-select-{{ section.id }}-{{ block.id }}-{{ opt_idx }}">{{ option.name | escape }}</label>
                        <div class="stl-select-wrap">
                          <select
                            id="stl-select-{{ section.id }}-{{ block.id }}-{{ opt_idx }}"
                            class="stl-select"
                            data-stl-option-index="{{ opt_idx }}"
                          >
                            {%- for value in option.values -%}
                              <option
                                value="{{ value | escape }}"
                                {% if option.selected_value == value %}
                                  selected
                                {% endif %}
                              >
                                {{ value | escape }}
                              </option>
                            {%- endfor -%}
                          </select>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                </div>

                <div class="stl-dialog__footer">
                  <button
                    type="submit"
                    name="add"
                    class="hb-btn hb-btn--{{ modal_btn_style }}"
                    data-stl-submit
                    {% unless modal_variant.available %}
                      disabled
                    {% endunless %}
                  >
                    <span class="hb-btn__label">
                      {%- if modal_variant.available -%}
                        {{ section.settings.add_to_cart_label | default: 'Add to cart' | escape }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                      {%- endif -%}
                    </span>
                    <span class="hb-btn__arrow">{{ arrow_svg }}</span>
                  </button>
                </div>
              {%- endform -%}

              <script type="application/json" id="stl-variants-{{ section.id }}-{{ block.id }}">
                {{ card_product.variants | json }}
              </script>
              <script type="application/json" id="stl-options-{{ section.id }}-{{ block.id }}">
                {{ card_product.options | json }}
              </script>
            {%- else -%}
              <div class="stl-empty-state">
                {{ section.settings.empty_product_message | default: 'Choose a product for this look in the theme editor.' | escape }}
              </div>
            {%- endif -%}
          </div>
        </dialog>
      {%- endfor -%}
    </div>

    {%- comment -%} Optional section CTAs (same pattern as header banner) {%- endcomment -%}
    {%- if section.settings.show_section_ctas -%}
      <div class="stl-section-ctas" style="display:flex;flex-wrap:wrap;gap:16px;margin-top:32px;justify-content:{{ section.settings.ctas_alignment }};">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="hb-btn hb-btn--{{ primary_btn_style }}" style="width:auto;">
            <span class="hb-btn__label">{{ section.settings.cta_primary_label | escape }}</span>
            <span class="hb-btn__arrow">{{ arrow_svg }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="hb-btn hb-btn--{{ secondary_btn_style }}" style="width:auto;">
            <span class="hb-btn__label">{{ section.settings.cta_secondary_label | escape }}</span>
            <span class="hb-btn__arrow">{{ arrow_svg }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
  </shop-the-look-root>
</section>

<script src="{{ 'shop-the-look.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Shop the look",
  "tag": "section",
  "class": "section-shop-the-look",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 1000,
      "max": 1600,
      "step": 10,
      "unit": "px",
      "label": "Max content width",
      "default": 1360
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Image corner radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 24
    },
    {
      "type": "header",
      "content": "Modal — Add to cart"
    },
    {
      "type": "select",
      "id": "modal_button_style",
      "label": "Add to cart button style",
      "options": [
        { "value": "primary", "label": "Primary (Black)" },
        { "value": "secondary", "label": "Secondary (Yellow)" }
      ],
      "default": "primary"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Add to cart button label",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "empty_product_message",
      "label": "Message when no product is selected",
      "default": "Choose a product for this look in the theme editor."
    },
    {
      "type": "header",
      "content": "Section buttons (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_section_ctas",
      "label": "Show section call-to-action buttons",
      "default": false
    },
    {
      "type": "select",
      "id": "ctas_alignment",
      "label": "Button alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button link",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "select",
      "id": "primary_button_style",
      "label": "Primary button style",
      "options": [
        { "value": "primary", "label": "Primary (Black)" },
        { "value": "secondary", "label": "Secondary (Yellow)" }
      ],
      "default": "primary",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button link",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    },
    {
      "type": "select",
      "id": "secondary_button_style",
      "label": "Secondary button style",
      "options": [
        { "value": "primary", "label": "Primary (Black)" },
        { "value": "secondary", "label": "Secondary (Yellow)" }
      ],
      "default": "secondary",
      "visible_if": "{{ section.settings.show_section_ctas }}"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot horizontal position",
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot vertical position",
          "default": 50
        },
        {
          "type": "text",
          "id": "hotspot_accessibility_label",
          "label": "Hotspot accessibility label",
          "default": "View product details",
          "info": "Announced by screen readers."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Variant options named like Color / Size (or common translations, e.g. Couleur, Taille, Farbe) use swatch and size styling. Other names render as a standard dropdown."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Shop the look",
      "blocks": [
        { "type": "look", "settings": { "hotspot_x": 59, "hotspot_y": 54 } },
        { "type": "look", "settings": { "hotspot_x": 82, "hotspot_y": 50 } },
        { "type": "look", "settings": { "hotspot_x": 60, "hotspot_y": 18 } },
        { "type": "look", "settings": { "hotspot_x": 70, "hotspot_y": 16 } },
        { "type": "look", "settings": { "hotspot_x": 49, "hotspot_y": 23 } },
        { "type": "look", "settings": { "hotspot_x": 74, "hotspot_y": 37 } }
      ]
    }
  ]
}
{% endschema %}
